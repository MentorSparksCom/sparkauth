# Database
DATABASE_URL=postgres://postgres:mysecretpassword@localhost:5432/loginserver?sslmode=disable

# Server
ISSUER_URL=http://localhost:9000
PORT=9000
SESSION_SECRET=change-this-to-a-long-random-string

# Initial admin user (created on first run)
ADMIN_EMAIL=admin@example.com

# SMTP (optional - magic links print to console if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# GitHub OAuth (optional - configure in admin UI or here)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
